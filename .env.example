# NavHub 环境变量示例 —— 复制为 .env 并填入真实值;.env 已被 .gitignore 忽略。
# 切勿提交真实密钥。完整的应用配置项见 config.example.toml。

# ── docker-compose 所需(postgres 服务与 navhub 共用)──────────────────────────
PG_USER=navhub
PG_PASSWORD=CHANGE_ME_strong_password
PG_DATABASE=navhub

# ── 可选:以环境变量覆盖应用配置(双下划线分隔层级,优先级高于 config.toml)──
# NAVHUB_CONFIG=/app/config.toml
# NAVHUB__SERVER__PORT=8088
# NAVHUB__SERVER__PUBLIC_URL=https://nav.example.com
# NAVHUB__DATABASE__HOST=postgres
# NAVHUB__REDIS__HOST=redis
# NAVHUB__REDIS__PASSWORD=
# NAVHUB__GENERAL__FAVICON_ALLOW_PRIVATE_TARGETS=false

# ── 可选:运行期开关(布尔/枚举,均有安全默认)────────────────────────────────
# NAVHUB_DEV=1                 # 开发模式:放行 localhost CORS、迁移完整性问题仅告警
# NAVHUB_LOG_FORMAT=json       # 日志格式 pretty|json(默认 pretty);亦可用 app.log_format
# NAVHUB_MIGRATION_STRICT=1    # 迁移 checksum 不一致时阻断启动(默认仅告警)
